# Copy this file to .env and fill in the real values.
# Never commit the populated .env (it is gitignored).
#
# These three are the Supabase publishable (anon) credentials used by the
# browser bundle. They are safe to expose to clients but should still live
# in .env so the repo can be re-pointed at a different Supabase project
# without code changes.

VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# Supabase Edge Function secrets (set in Dashboard → Edge Functions → Secrets):
# RESEND_API_KEY — transactional email
# STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET — payments
# CRON_SECRET — scheduled intake reminders
# STAFF_NOTIFICATION_PHONE — staff alert destination (if re-enabled later)
# LOVABLE_API_KEY — clinical AI (recommend-lab-panel, parse-zrt-labs) until Anthropic migration
# PDFSHIFT_API_KEY — required for Rx fax PDF generation (send-rx-fax)
# TELNYX_API_KEY, TELNYX_FAX_CONNECTION_ID, TELNYX_FAX_FROM_NUMBER — Supabase secrets only (fax)
# APP_BASE_URL — production site origin for intake magic links (default https://elevatedhealthaugusta.com)
#
# Patient/staff SMS: GoHighLevel (requires GHL_API_KEY + GHL_LOCATION_ID in Supabase secrets).
